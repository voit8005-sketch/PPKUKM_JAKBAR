# Sudin PPKUKM Portal - Environment Configuration
# Copy to .env and update values

# Flask
SECRET_KEY=your-very-long-random-secret-key-here-change-in-production!

# Database (MySQL)
DB_USER=root
DB_PASS=your-mysql-password
DB_HOST=localhost
DB_NAME=ppkukm_portal

# Upload (optional overrides)
UPLOAD_FOLDER_PHOTOS=static/uploads/news/photos
UPLOAD_FOLDER_VIDEOS=static/uploads/news/videos

# Example .env file:
# SECRET_KEY=my-super-secret-key-2024-change-this!
# DB_USER=root
# DB_PASS=mypassword123
# DB_HOST=localhost
# DB_NAME=ppkukm_portal
